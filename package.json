{
  "name": "pdf-merge",
  "productName": "PDF 合并工具",
  "version": "1.0.0",
  "description": "Electron PDF 合并工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "hot": "nodemon --watch src --watch package.json --exec \"electron .\"",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.pdfmerge.app",
    "productName": "PDF 合并工具",
    "icon": "build/icon.png",
    "asar": true,
    "compression": "maximum",
    "files": [
      "src/**/*",
      "package.json",
      "build/icon.png"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4"
  }
}
